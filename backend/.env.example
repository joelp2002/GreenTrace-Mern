# MongoDB — ang "base" database ay nasa URI path: ...mongodb.net/NAMEDB?...
# Halimbawa Atlas: mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/greentrace?retryWrites=true&w=majority
# Local: mongodb://127.0.0.1:27017/greentrace
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/greentrace?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=5001
NODE_ENV=development

# CORS — comma-separated origins (Vercel preview + production URLs)
FRONTEND_URL=http://localhost:5173

# Public URL of this API (used in uploaded file responses). On Render: https://your-service.onrender.com
API_PUBLIC_URL=http://localhost:5001
